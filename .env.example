# ============================================================
# Sentinel CLI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# Never commit the .env file to version control!
#
# Sentinel defaults to free open-source models (Llama 3 on Groq).
# Connect your paid subscriptions below to access premium models.
#
# Quick start (free): just set GROQ_API_KEY and you're good to go.
# Quick start (local): install Ollama — no keys needed at all.
# ============================================================

# ============================================================
# AI Provider API Keys
# ============================================================
# Sentinel uses defaults that give you the best free experience.
# Premium providers are optional — connect your existing subscriptions.

# Free open-source (default) — Groq offers free API access to Llama 3, Gemma, Qwen
GROQ_API_KEY=your-groq-key

# OpenAI — Connect your ChatGPT Plus/Pro subscription
# ChatGPT Plus/Pro users get API credits included with their plan
OPENAI_API_KEY=sk-your-openai-key

# Anthropic — Connect your Claude Pro/Max subscription
# Claude Pro/Max/Team users get API credits included with their plan
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini — generous free tier, no API key required for limited use
GEMINI_API_KEY=your-gemini-key

# OpenRouter — access 200+ models from one API
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# DeepSeek — cheap reasoning models
DEEPSEEK_API_KEY=your-deepseek-key

# Mistral — Codestral for code generation
MISTRAL_API_KEY=your-mistral-key

# xAI / Grok
XAI_API_KEY=your-xai-key

# Together AI — fast open-source inference
TOGETHER_API_KEY=your-together-key

# Fireworks AI — fastest inference for open models
FIREWORKS_API_KEY=your-fireworks-key

# Perplexity — models with live web search
PERPLEXITY_API_KEY=your-perplexity-key

# GitHub Copilot — use your existing GitHub Copilot subscription
# Models: copilot/gpt-4o, copilot/claude-sonnet
# Uses the same GITHUB_TOKEN as GitHub API access
GITHUB_TOKEN=your-github-token
# Or use a dedicated Copilot token:
# GITHUB_COPILOT_TOKEN=your-copilot-token

# Local providers (free, no API key needed)
# Ollama — fully local: https://ollama.com
OLLAMA_HOST=http://localhost:11434
# LM Studio — local OpenAI-compatible server
LMSTUDIO_HOST=http://localhost:1234

# ============================================================
# Provider notes
# ============================================================
# - Sentinel defaults to free open-source models (Groq free tier)
# - Each provider is optional — missing keys skip that provider
# - Use /auth in the TUI to check your connection status
# - Use /connect in the TUI for guided setup help
# - Use /setup in the TUI for interactive key setup wizard

# ============================================================
# Integration API Keys (NEW in v1.3.0)
# ============================================================

# GitHub Token (for PR reviews and GitHub Security)
# Required for: sentinel review-pr, sentinel sarif upload
GITHUB_TOKEN=your-github-token

# Slack Webhook URL (for notifications)
# Get one at: https://api.slack.com/messaging/webhooks
# Required for: sentinel notify --slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Discord Webhook URL (for notifications)
# Get one at: Discord Server Settings > Integrations > Webhooks
# Required for: sentinel notify --discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ============================================================
# Analyzer Configuration
# ============================================================

# Override default analyzers (comma-separated)
# Options: security,quality,bugs,performance,dependency,accessibility,typescript,react,api,secrets,custom
# SENTINEL_ANALYZERS=security,quality,bugs,performance

# Enable real-time CVE checking via npm audit (default: true)
# SENTINEL_REALTIME_CVE=true

# Entropy threshold for secret detection (default: 4.5)
# SENTINEL_ENTROPY_THRESHOLD=4.5

# ============================================================
# Optional Configurations
# ============================================================

# Maximum parallel API calls (default: 3)
# SENTINEL_MAX_PARALLEL=3

# Cache TTL in minutes (default: 1440 = 24 hours)  
# SENTINEL_CACHE_TTL=1440

# Enable debug logging
# SENTINEL_DEBUG=true

# Auto-fix found issues (PR review bot only)
# When true, Sentinel will push fixes for medium/low severity issues directly to the PR branch
# Critical and high severity issues always require human review
# AUTO_FIX=true

# Parallel AI model review (PR review bot only)
# When true, runs 4 parallel AI model reviews and merges results
# PARALLEL_REVIEW=true

# LSP integration (PR review bot only)
# When true, enriches review with language server diagnostics (typescript-language-server, pyright, gopls, rust-analyzer)
# LSP_ENABLED=true

# Default output format (console, json, html, markdown, sarif)
# SENTINEL_FORMAT=console

# ============================================================
# CI/CD Integrations
# ============================================================

# GitLab Token (for MR comments)
# GITLAB_TOKEN=your-gitlab-token

# Azure DevOps Token
# AZURE_DEVOPS_TOKEN=your-azure-token

# Bitbucket Token
# BITBUCKET_TOKEN=your-bitbucket-token

# ============================================================
# Docker Configuration
# ============================================================

# Set automatically when running in Docker
# SENTINEL_DOCKER=true

# ============================================================
# Notes
# ============================================================
# - AI API keys are optional - Sentinel works without them
# - Missing keys will skip that provider automatically
# - You can enable/disable providers with 'sentinel models'
# - GitHub token needed only for PR reviews and SARIF upload
# - Slack/Discord webhooks needed only for notifications
